# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ── AegisMimic runtime files ──────────────────────────────────────────
# Audit logs — contain sensitive forensic data, never commit
audit/
audit/*.log
audit/*.ndjson

# Forensic snapshots — contain captured process data
snapshots/

# ── Config — DO commit policy.yaml, but never real credentials ────────
# If you create a local override, exclude it:
config/policy.local.yaml
config/*.local.yaml

# ── Docker ────────────────────────────────────────────────────────────
.docker/

# ── Environment ───────────────────────────────────────────────────────
.env
.env.*
*.env.local

# ── IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
